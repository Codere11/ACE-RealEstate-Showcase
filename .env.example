# ACE Real Estate - Environment Variables
# Copy this file to .env and update with your values

# Database Configuration
# For local PostgreSQL:
DATABASE_URL=postgresql://ace_user:ace_dev_password_change_in_production@localhost:5432/ace_production

# For production (Render/Railway/etc):
# DATABASE_URL=postgresql://user:password@host:5432/database

# API Keys / LLM
OPENAI_API_KEY=your-openai-api-key-here
ACE_LLM_PROVIDER=openai
ACE_LLM_MODEL=gpt-4.1-mini

# Security
ACE_SECRET=your-secret-key-for-jwt-tokens-change-this-in-production

# Payments
ACE_PAYMENT_PROVIDER=mock
ACE_PUBLIC_BASE_URL=http://localhost:8000
ACE_MANAGER_DASHBOARD_URL=http://localhost:4400
STRIPE_SECRET_KEY=
STRIPE_CONNECT_CLIENT_ID=
STRIPE_WEBHOOK_SECRET=

# Application Settings
ACE_LOG_LEVEL=INFO
ACE_ENFORCE_DUAL_CONTACT=1

# CORS Origins (comma-separated)
# Add your frontend URLs here
CORS_ORIGINS=http://localhost:4200,http://localhost:4400,http://localhost:4500
